tax_data <- data.frame(
Family = c("Syrphidae", "Syrphidae", "Syrphidae"),
Genus = c("Eristalis", "Eristalis", NA),
Species = c("Eristalis tenax", NA, NA),
nom = c("Eristalis tenax", "Eristalis sp.", "Syrphidae indet."),
Determination = c("Species", "Genus", "Family"),
total = c(10, 5, 2)
)
hierarchy <- c("Family", "Genus", "Species")
Harmony_decision(tax_data, 0.5, hierarchy)
pkgload::dev_help('Datacheck_fun')
