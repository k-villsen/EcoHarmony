Family = c("Syrphidae", NA),
Genus = c("Eristalis", "Eristalis"),
nom = c("Eristalis tenax", "Eristalis sp."),
Determination = c("Species", "Genus")
)Datacheck_fun(Dat, c("Family", "Genus", "Species"))
